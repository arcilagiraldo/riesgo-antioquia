# Copia este archivo como .env y completa los valores
# Railway inyecta DATABASE_URL automáticamente cuando agregas el plugin PostgreSQL

# Base de datos (Railway lo pone solo si usas su plugin)
DATABASE_URL=postgresql://usuario:password@host:5432/riesgo_antioquia

# API keys opcionales — sin ellas el motor local gratuito funciona igual
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Entorno
ENV=production
